# --- Растягиваем ВСЕ фоны game/images/scene_*.png на весь экран 1920x1080 ---
# Иначе Ren'Py рисует картинку в её родном размере в углу, и вокруг остаётся
# чёрная рамка, а диалог кажется "съехавшим" относительно фона.
init python:
    for _bg in renpy.list_files():
        if _bg.startswith("images/scene_") and _bg.endswith(".png") and "/" not in _bg[len("images/"):]:
