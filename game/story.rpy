# ===== Экранная карточка с текстом =====
screen card_screen(msg, tsize=64):
    add Solid("#000000")
    text msg:
        xalign 0.5
        yalign 0.5
        text_align 0.5
        size tsize
        color "#ffffff"
        xsize 1750
        line_spacing 6

# Карточка на N секунд, затем автопереход
label card_timed(msg, secs=4.0, tsize=64):
    scene black with fade
    show screen card_screen(msg, tsize)
    $ renpy.pause(secs)
    hide screen card_screen
    return

# Карточка до нажатия (для длинных концовок)
label card_click(msg, tsize=30):
    scene black with fade
    show screen card_screen(msg, tsize)
    pause
    hide screen card_screen
    return


# ===== Проигрывание видео БЕЗ пропуска =====
# Во время ролика кнопки скрыты и клик не перелистывает — переход дальше только после конца видео.
# Длительность каждого ролика в СЕКУНДАХ — ПОСТАВЬ РЕАЛЬНЫЕ ЗНАЧЕНИЯ:
define VIDEO_LEN = {
    "scene_4_1": 8.0,
    "scene_5_1": 7.0,
    "scene_23_1": 4.0,
    "scene_24_1": 8.0,
    "scene_29_1": 6.0,
}

label play_video(vid):
    $ quick_menu = False
    window hide
    $ renpy.scene()
    $ renpy.show("videoplayer", what=Transform(Movie(play="video/" + vid + ".webm"), xysize=(1920, 1080), fit="cover", align=(0.5, 0.5)))
    $ renpy.pause(VIDEO_LEN.get(vid, 5.0), hard=True)
    $ renpy.hide("videoplayer")
    $ quick_menu = True
    return


# ===== Газета (Сцена 16): текст на экране, продолжить — удержать 8 сек =====
screen hold_to_continue(msg, hold_time=8.0):
    modal True
    default holding = False
    default progress = 0.0

    add Solid("#000000")
    text msg:
        xalign 0.5
        yalign 0.46
        xsize 1820
        size 34
        color "#eeeeee"
        line_spacing 6
    text "Удерживайте экран, чтобы продолжить  ([int(hold_time - progress)])":
        xalign 0.5
        yalign 0.97
        size 30
        color "#bbbbbb"

    key "mousedown_1" action SetScreenVariable("holding", True)
    key "mouseup_1" action [SetScreenVariable("holding", False), SetScreenVariable("progress", 0.0)]

    if holding:
        timer 0.1 repeat True action SetScreenVariable("progress", progress + 0.1)
    if progress >= hold_time:
        timer 0.01 action Return(True)


